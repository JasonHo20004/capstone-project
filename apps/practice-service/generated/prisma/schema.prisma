// =============================================================================
// Practice Service - Prisma Schema
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("PRACTICE_DATABASE_URL")
  directUrl = env("PRACTICE_DIRECT_URL")
}

enum ExamType {
  IELTS
  TOEFL
  TOEIC
}

enum QuestionType {
  MULTIPLE_CHOICE
  GAP_FILL
  MATCHING
  TRUE_FALSE_NOT_GIVEN
}

model PracticeTest {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String        @db.VarChar(255)
  examType  ExamType      @default(IELTS) @map("exam_type")
  status    String        @default("DRAFT") @db.VarChar(50)
  duration  Int // Overall duration in minutes
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  sections  ExamSection[]

  @@map("practice_tests")
}

model ExamSection {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceTestId String       @map("practice_test_id") @db.Uuid
  test           PracticeTest @relation(fields: [practiceTestId], references: [id], onDelete: Cascade)
  name           String       @db.VarChar(100) // "Reading", "Listening"
  orderIndex     Int          @map("order_index")
  parts          ExamPart[]

  @@map("exam_sections")
}

model ExamPart {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examSectionId  String          @map("exam_section_id") @db.Uuid
  section        ExamSection     @relation(fields: [examSectionId], references: [id], onDelete: Cascade)
  name           String          @db.VarChar(100) // "Passage 1", "Section 1"
  content        String? // Reading text
  mediaUrl       String?         @map("media_url") // Listening S3 audio URL
  orderIndex     Int             @map("order_index")
  questionGroups QuestionGroup[]

  @@map("exam_parts")
}

model QuestionGroup {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examPartId   String     @map("exam_part_id") @db.Uuid
  part         ExamPart   @relation(fields: [examPartId], references: [id], onDelete: Cascade)
  instructions String? // e.g., "Choose NO MORE THAN TWO WORDS..."
  imageUrls    String[]   @map("image_urls") // Optional images for diagram labeling
  orderIndex   Int        @map("order_index")
  questions    Question[]

  @@map("question_groups")
}

model Question {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionGroupId String        @map("question_group_id") @db.Uuid
  group           QuestionGroup @relation(fields: [questionGroupId], references: [id], onDelete: Cascade)
  type            QuestionType
  content         Json // JSONB field for question-specific UI render data (options, gaps)
  answer          Json // JSONB field for grading logic (correct options, exact text variants) // e.g., ["colour", "color"]
  explanation     String? // Explanation shown after test submitted
  orderIndex      Int           @map("order_index")

  @@map("questions")
}
