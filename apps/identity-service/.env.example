IDENTITY_SERVICE_PORT=3001
NODE_ENV=development

# Database
IDENTITY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/identity_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT Secrets
ACCESS_TOKEN_SECRET=your-secret-key-change-in-production
REFRESH_TOKEN_SECRET=your-refresh-secret-key-change-in-production
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d
