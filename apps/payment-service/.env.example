PAYMENT_SERVICE_PORT=3005
NODE_ENV=development

# Database
PAYMENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payment_db?schema=public
PAYMENT_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/payment_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT Secrets
ACCESS_TOKEN_SECRET=your-secret-key-change-in-production

# VNPay sandbox (đăng ký tại https://sandbox.vnpayment.vn/devreg/)
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Backend endpoint VNPay redirect browser sau khi thanh toán
VNPAY_RETURN_URL=http://localhost:3000/api/topup-orders/vnpay-return
# Backend IPN endpoint VNPay gọi server-to-server
VNPAY_IPN_URL=http://localhost:3000/api/topup-orders/ipn

FRONTEND_URL=http://localhost:5173
