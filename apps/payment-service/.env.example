PAYMENT_SERVICE_PORT=3005
NODE_ENV=development

# Database
PAYMENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payment_db?schema=public
PAYMENT_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/payment_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT Secrets
ACCESS_TOKEN_SECRET=your-secret-key-change-in-production

# Stripe sandbox (lấy key tại https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# Currency cho Checkout. VND là zero-decimal (mặc định). Đổi 'usd' nếu muốn test card US.
STRIPE_CURRENCY=vnd

# Backend public URL — Stripe redirect browser về đây sau khi thanh toán/huỷ.
BACKEND_URL=http://localhost:3000
# Frontend URL — backend redirect cuối cùng về trang /payment/result.
FRONTEND_URL=http://localhost:5173
