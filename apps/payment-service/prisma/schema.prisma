
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("PAYMENT_DATABASE_URL")
  directUrl = env("PAYMENT_DIRECT_URL")
}

model Wallet {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  allowance      Decimal       @default(0.00) @db.Decimal(12, 2)
  pendingBalance Decimal       @default(0.00) @map("pending_balance") @db.Decimal(12, 2)
  userId         String        @unique @map("user_id") @db.Uuid
  transactions   Transaction[]

  @@map("wallets")
}

model Transaction {
  id                     String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  amount                 Decimal               @db.Decimal(12, 2)
  status                 TransactionStatus
  createdAt              DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  description            String?
  walletId               String                @map("wallet_id") @db.Uuid
  transactionType        TransactionType       @map("transaction_type")
  topupOrderId           String?               @map("topup_order_id") @db.Uuid
  orderId                String?               @unique @map("order_id") @db.Uuid

  order                  Order?                @relation(fields: [orderId], references: [id])
  topupOrder             TopupOrder?           @relation(fields: [topupOrderId], references: [id])
  wallet                 Wallet                @relation(fields: [walletId], references: [id])

  @@map("transactions")
}

model TopupOrder {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  realMoney          Decimal       @map("real_money") @db.Decimal(12, 2)
  realAmount         Decimal?      @map("real_amount") @db.Decimal(12, 2)
  currency           String        @default("VND") @db.VarChar(10)
  paymentMethod      PaymentMethod @map("payment_method")
  status             OrderStatus
  // @map keeps original column names → no DB migration needed when swapping providers.
  stripeSessionId         String? @unique @map("vnpay_txn_ref") @db.VarChar(255)
  stripePaymentIntentId   String? @map("vnpay_transaction_no") @db.VarChar(255)
  stripePaymentMethodType String? @map("vnpay_bank_code") @db.VarChar(50)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  transactions       Transaction[]

  @@map("topup_orders")
}

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?    @unique @map("user_id") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  cartItems CartItem[]
  orders    Order[]

  @@map("carts")
}

model CartItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  addedAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  priceAtTime Decimal  @map("price_at_time") @db.Decimal(12, 2)
  cartId      String   @map("cart_id") @db.Uuid
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model Order {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  totalAmount Decimal      @map("total_amount") @db.Decimal(12, 2)
  /// Pre-discount subtotal recorded for audit. Null on legacy orders.
  subtotal    Decimal?     @map("subtotal") @db.Decimal(12, 2)
  /// Amount discounted off the subtotal by an applied coupon.
  discount    Decimal      @default(0) @map("discount") @db.Decimal(12, 2)
  /// Coupon used at checkout (snapshotted by id; code preserved separately).
  couponId    String?      @map("coupon_id") @db.Uuid
  couponCode  String?      @map("coupon_code") @db.VarChar(40)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  cartId      String       @map("cart_id") @db.Uuid
  cart        Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  coupon      Coupon?      @relation(fields: [couponId], references: [id])
  transaction Transaction?
  refundRequests RefundRequest[]

  @@map("orders")
}

// ── Coupon / discount codes ─────────────────────────────────────────────
// Admin creates codes; learners apply at cart/checkout. A coupon either
// reduces by a flat amount (FIXED) or a percentage (PERCENT, 0–100).
// `maxRedemptions` is the global cap; `maxPerUser` caps a single user's reuse.
model Coupon {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String        @unique @db.VarChar(40)
  description     String?       @db.Text
  discountType    CouponType    @map("discount_type")
  discountValue   Decimal       @map("discount_value") @db.Decimal(12, 2)
  maxDiscount     Decimal?      @map("max_discount") @db.Decimal(12, 2)
  minOrderAmount  Decimal       @default(0) @map("min_order_amount") @db.Decimal(12, 2)
  maxRedemptions  Int?          @map("max_redemptions")
  maxPerUser      Int?          @map("max_per_user")
  usedCount       Int           @default(0) @map("used_count")
  startsAt        DateTime?     @map("starts_at") @db.Timestamptz(6)
  expiresAt       DateTime?     @map("expires_at") @db.Timestamptz(6)
  isActive        Boolean       @default(true) @map("is_active")
  createdById     String?       @map("created_by_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  orders          Order[]
  redemptions     CouponRedemption[]

  @@index([isActive, expiresAt])
  @@map("coupons")
}

model CouponRedemption {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couponId  String   @map("coupon_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([couponId, orderId])
  @@index([couponId, userId])
  @@map("coupon_redemptions")
}

enum CouponType {
  PERCENT
  FIXED
}

// ── Refund workflow ─────────────────────────────────────────────────────
// Learner requests a refund on a paid order; admin approves/rejects.
// On approve the requested amount goes back to the learner's wallet; the
// seller_earnings rows for that order are marked REFUNDED so payouts skip them.
model RefundRequest {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String              @map("order_id") @db.Uuid
  requesterId  String              @map("requester_id") @db.Uuid
  amount       Decimal             @db.Decimal(12, 2)
  reason       String              @db.Text
  status       RefundRequestStatus @default(PENDING)
  adminId      String?             @map("admin_id") @db.Uuid
  adminNote    String?             @map("admin_note") @db.Text
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  processedAt  DateTime?           @map("processed_at") @db.Timestamptz(6)

  order        Order               @relation(fields: [orderId], references: [id])

  @@index([requesterId, createdAt])
  @@index([status, createdAt])
  @@map("refund_requests")
}

enum RefundRequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum UserPlanType {
  FREE
  PRO
}

model UserPlan {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @unique @db.VarChar(100)
  type        UserPlanType @unique
  price       Decimal      @default(0) @db.Decimal(12, 2)
  description String?
  features    String[]
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?    @updatedAt @map("updated_at") @db.Timestamptz(6)

  userSubscriptions UserSubscription[]

  @@map("user_plans")
}

model UserSubscription {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  planId    String    @map("plan_id") @db.Uuid
  startDate DateTime  @default(now()) @map("start_date") @db.Timestamptz(6)
  endDate   DateTime? @map("end_date") @db.Timestamptz(6)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  plan UserPlan @relation(fields: [planId], references: [id])

  @@map("user_subscriptions")
}

// ── Revenue Split (Commission) ──────────────────────────────────────────

model SellerEarning {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId         String        @map("seller_id") @db.Uuid
  courseId          String        @map("course_id") @db.Uuid
  orderId          String        @map("order_id") @db.Uuid
  buyerId          String        @map("buyer_id") @db.Uuid
  totalAmount      Decimal       @map("total_amount") @db.Decimal(12, 2)
  gatewayFee       Decimal       @default(0) @map("gateway_fee") @db.Decimal(12, 2)
  netAmount        Decimal       @default(0) @map("net_amount") @db.Decimal(12, 2)
  commissionRate   Decimal       @map("commission_rate") @db.Decimal(5, 4)
  commissionAmount Decimal       @map("commission_amount") @db.Decimal(12, 2)
  sellerAmount     Decimal       @map("seller_amount") @db.Decimal(12, 2)
  status           EarningStatus @default(PENDING)
  availableAt      DateTime      @map("available_at") @db.Timestamptz(6)
  releasedAt       DateTime?     @map("released_at") @db.Timestamptz(6)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("seller_earnings")
}

model CommissionConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId        String?  @unique @map("seller_id") @db.Uuid
  commissionRate  Decimal  @default(0.3000) @map("commission_rate") @db.Decimal(5, 4)
  gatewayFeeRate  Decimal  @default(0.0300) @map("gateway_fee_rate") @db.Decimal(5, 4)
  gatewayFeeFixed Decimal  @default(2000) @map("gateway_fee_fixed") @db.Decimal(12, 2)
  clearanceDays   Int      @default(7) @map("clearance_days")
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("commission_configs")
}

enum EarningStatus {
  PENDING
  AVAILABLE
  RELEASED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  VNPAY
  ZALOPAY
  BANKING
  APPLEPAY
}

enum OrderStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TransactionType {
  DEPOSIT
  PAYMENT
  WITHDRAW
  SUBSCRIPTION
  COMMISSION
  SELLER_EARNING
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WithdrawalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ── Payouts (Withdrawals) ───────────────────────────────────────────────

model WithdrawalRequest {
  id            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId      String                  @map("seller_id") @db.Uuid
  amount        Decimal                 @db.Decimal(12, 2)
  bankName      String                  @map("bank_name")
  accountName   String                  @map("account_name")
  accountNumber String                  @map("account_number")
  status        WithdrawalRequestStatus @default(PENDING)
  proofImageUrl String?                 @map("proof_image_url")
  adminNote     String?                 @map("admin_note")
  createdAt     DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  processedAt   DateTime?               @map("processed_at") @db.Timestamptz(6)
  /// Seller cancelled this PENDING request before admin acted.
  cancelledAt   DateTime?               @map("cancelled_at") @db.Timestamptz(6)
  /// Optional pointer back to the original rejected request when seller
  /// retried — lets the timeline show "rút lại sau khi bị từ chối".
  retriedFromId String?                 @map("retried_from_id") @db.Uuid

  @@index([sellerId, createdAt])
  @@map("withdrawal_requests")
}
