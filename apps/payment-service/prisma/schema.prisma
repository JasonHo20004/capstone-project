
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("PAYMENT_DATABASE_URL")
  directUrl = env("PAYMENT_DIRECT_URL")
}

model Wallet {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  allowance      Decimal       @default(0.00) @db.Decimal(12, 2)
  pendingBalance Decimal       @default(0.00) @map("pending_balance") @db.Decimal(12, 2)
  userId         String        @unique @map("user_id") @db.Uuid
  transactions   Transaction[]

  @@map("wallets")
}

model Transaction {
  id                     String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  amount                 Decimal               @db.Decimal(12, 2)
  status                 TransactionStatus
  createdAt              DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  description            String?
  walletId               String                @map("wallet_id") @db.Uuid
  transactionType        TransactionType       @map("transaction_type")
  topupOrderId           String?               @map("topup_order_id") @db.Uuid
  subscriptionContractId String?               @map("subscription_contract_id") @db.Uuid
  orderId                String?               @unique @map("order_id") @db.Uuid
  
  order                  Order?                @relation(fields: [orderId], references: [id])
  subscriptionContract   SubscriptionContract? @relation(fields: [subscriptionContractId], references: [id])
  topupOrder             TopupOrder?           @relation(fields: [topupOrderId], references: [id])
  wallet                 Wallet                @relation(fields: [walletId], references: [id])

  @@map("transactions")
}

model TopupOrder {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String        @map("user_id") @db.Uuid
  realMoney             Decimal       @map("real_money") @db.Decimal(12, 2)
  realAmount            Decimal?      @map("real_amount") @db.Decimal(12, 2)
  currency              String        @default("VND") @db.VarChar(10)
  paymentMethod         PaymentMethod @map("payment_method")
  status                OrderStatus
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id") @db.VarChar(255)
  stripeClientSecret    String?       @map("stripe_client_secret") @db.VarChar(255)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  transactions          Transaction[]

  @@map("topup_orders")
}

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?    @unique @map("user_id") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  cartItems CartItem[]
  orders    Order[]

  @@map("carts")
}

model CartItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  addedAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  priceAtTime Float    @map("price_at_time")
  cartId      String   @map("cart_id") @db.Uuid
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model Order {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  totalAmount Float        @map("total_amount")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  cartId      String       @map("cart_id") @db.Uuid
  cart        Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  transaction Transaction?

  @@map("orders")
}

model SubscriptionPlan {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String                 @unique @db.VarChar(255)
  description           String?
  maxCourses            Int                    @map("max_courses")
  monthlyFee            Decimal                @map("monthly_fee") @db.Decimal(10, 2)
  subscriptionContracts SubscriptionContract[]

  @@map("subscription_plans")
}

model SubscriptionContract {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseSellerId     String           @map("course_seller_id") @db.Uuid
  status             Boolean          @default(true)
  subscriptionPlanId String           @map("subscription_plan_id") @db.Uuid
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt          DateTime         @map("expires_at") @db.Timestamptz(6)
  updatedAt          DateTime?        @updatedAt @map("updated_at") @db.Timestamptz(6)
  renewalCount       Int              @default(0) @map("renewal_count")
  lastRenewalAt      DateTime?        @map("last_renewal_at") @db.Timestamptz(6)
  notes              String?
  lastNotificationAt DateTime?        @map("last_notification_at") @db.Timestamptz(6)
  subscriptionPlan   SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])
  transactions       Transaction[]

  @@map("subscription_contracts")
}

enum UserPlanType {
  FREE
  PRO
}

model UserPlan {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @unique @db.VarChar(100)
  type        UserPlanType @unique
  price       Decimal      @default(0) @db.Decimal(12, 2)
  description String?
  features    String[]
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?    @updatedAt @map("updated_at") @db.Timestamptz(6)

  userSubscriptions UserSubscription[]

  @@map("user_plans")
}

model UserSubscription {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  planId    String    @map("plan_id") @db.Uuid
  startDate DateTime  @default(now()) @map("start_date") @db.Timestamptz(6)
  endDate   DateTime? @map("end_date") @db.Timestamptz(6)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  plan UserPlan @relation(fields: [planId], references: [id])

  @@map("user_subscriptions")
}

// ── Revenue Split (Commission) ──────────────────────────────────────────

model SellerEarning {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId         String        @map("seller_id") @db.Uuid
  courseId          String        @map("course_id") @db.Uuid
  orderId          String        @map("order_id") @db.Uuid
  buyerId          String        @map("buyer_id") @db.Uuid
  totalAmount      Decimal       @map("total_amount") @db.Decimal(12, 2)
  gatewayFee       Decimal       @default(0) @map("gateway_fee") @db.Decimal(12, 2)
  netAmount        Decimal       @default(0) @map("net_amount") @db.Decimal(12, 2)
  commissionRate   Decimal       @map("commission_rate") @db.Decimal(5, 4)
  commissionAmount Decimal       @map("commission_amount") @db.Decimal(12, 2)
  sellerAmount     Decimal       @map("seller_amount") @db.Decimal(12, 2)
  status           EarningStatus @default(PENDING)
  availableAt      DateTime      @map("available_at") @db.Timestamptz(6)
  releasedAt       DateTime?     @map("released_at") @db.Timestamptz(6)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("seller_earnings")
}

model CommissionConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId        String?  @unique @map("seller_id") @db.Uuid
  commissionRate  Decimal  @default(0.3000) @map("commission_rate") @db.Decimal(5, 4)
  gatewayFeeRate  Decimal  @default(0.0300) @map("gateway_fee_rate") @db.Decimal(5, 4)
  gatewayFeeFixed Decimal  @default(2000) @map("gateway_fee_fixed") @db.Decimal(12, 2)
  clearanceDays   Int      @default(7) @map("clearance_days")
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("commission_configs")
}

enum EarningStatus {
  PENDING
  AVAILABLE
  RELEASED
}

enum PaymentMethod {
  STRIPE
  ZALOPAY
  BANKING
  APPLEPAY
}

enum OrderStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TransactionType {
  DEPOSIT
  PAYMENT
  MONTHLYFEE
  WITHDRAW
  SUBSCRIPTION
  COMMISSION
  SELLER_EARNING
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WithdrawalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── Payouts (Withdrawals) ───────────────────────────────────────────────

model WithdrawalRequest {
  id            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId      String                  @map("seller_id") @db.Uuid
  amount        Decimal                 @db.Decimal(12, 2)
  bankName      String                  @map("bank_name")
  accountName   String                  @map("account_name")
  accountNumber String                  @map("account_number")
  status        WithdrawalRequestStatus @default(PENDING)
  proofImageUrl String?                 @map("proof_image_url")
  adminNote     String?                 @map("admin_note")
  createdAt     DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  processedAt   DateTime?               @map("processed_at") @db.Timestamptz(6)

  @@map("withdrawal_requests")
}
