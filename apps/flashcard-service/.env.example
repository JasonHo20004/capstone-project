FLASHCARD_SERVICE_PORT=3004
NODE_ENV=development

# Database
FLASHCARD_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flashcard_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT Secrets
ACCESS_TOKEN_SECRET=your-secret-key-change-in-production

# Pexels Video API (free at pexels.com/api)
PEXELS_API_KEY=your-pexels-api-key-here
