// =============================================================================
// Course Service - Prisma Schema
// Tables: Course, Lesson, MediaAsset, Comment, Rating, Report, UserLesson
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("COURSE_DATABASE_URL")
  directUrl = env("COURSE_DIRECT_URL")
}

model Course {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String         @db.VarChar(100)
  description    String?
  price          Decimal        @db.Decimal(10, 2)
  courseLevel    CourseLevel?   @map("course_level")
  courseSellerId String         @map("course_seller_id") @db.Uuid
  finalTestId    String?        @map("final_test_id") @db.Uuid
  ratingCount    Int?           @map("rating_count")
  status         CourseStatus   @default(PENDING)
  category       String?        @db.VarChar(100)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  thumbnailUrl   String?        @map("thumbnail_url")

  // Review workflow metadata — latest timestamps, overwritten on re-submission.
  // Full audit trail lives in CourseReviewHistory.
  submittedAt      DateTime? @map("submitted_at") @db.Timestamptz(6)
  approvedAt       DateTime? @map("approved_at") @db.Timestamptz(6)
  rejectedAt       DateTime? @map("rejected_at") @db.Timestamptz(6)
  rejectionReason  String?   @map("rejection_reason")
  reviewedById     String?   @map("reviewed_by_id") @db.Uuid

  modules        Module[]
  lessons        Lesson[]
  ratings        Rating[]
  reports        Report[]
  userActivities UserActivity[]
  reviewHistory  CourseReviewHistory[]
  certificates   Certificate[]

  @@index([courseSellerId])
  @@index([status])
  @@map("courses")
}

/// Append-only audit trail of every status change in the review workflow:
/// seller submissions, admin approvals, admin rejections.
model CourseReviewHistory {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId     String   @map("course_id") @db.Uuid
  fromStatus   CourseStatus @map("from_status")
  toStatus     CourseStatus @map("to_status")
  actorId      String   @map("actor_id") @db.Uuid
  /// "seller" | "admin" — denormalised so the seller-facing timeline can
  /// label entries without an extra identity-service lookup.
  actorRole    String   @map("actor_role") @db.VarChar(20)
  reason       String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, createdAt])
  @@map("course_review_history")
}

model Module {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String   @db.VarChar(150)
  description String?
  moduleOrder Int      @map("module_order")
  courseId    String   @map("course_id") @db.Uuid

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  @@unique([courseId, moduleOrder])
  @@index([courseId, moduleOrder])
  @@map("modules")
}

model Lesson {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String       @db.VarChar(100)
  description       String?
  durationInSeconds Float?       @map("duration_in_seconds")
  lessonOrder       Int?         @map("lesson_order")
  materials         String[]
  commentCount      Int?         @map("comment_count")
  courseId          String       @map("course_id") @db.Uuid
  moduleId          String?      @map("module_id") @db.Uuid
  /// UUID of a Test in assessment-service. When set, this lesson is a quiz
  /// lesson — clients render a test launcher instead of a video player.
  /// No DB-level FK because the Test lives in a different database.
  testId            String?      @map("test_id") @db.Uuid

  comments          Comment[]
  course            Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module            Module?      @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  mediaAssets       MediaAsset[]
  userLessons       UserLesson[]

  @@unique([moduleId, lessonOrder])
  @@index([testId])
  @@map("lessons")
}

model MediaAsset {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetType MediaType @map("asset_type")
  assetUrl  String    @unique @map("asset_url")
  lessonId  String    @map("lesson_id") @db.Uuid
  lesson    Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("media_assets")
}

model Comment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content         String
  userId          String   @map("user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  parentCommentId String?  @map("parent_comment_id") @db.Uuid
  lessonId        String   @map("lesson_id") @db.Uuid

  // Edit metadata — only set after first edit. editHistory stores prior
  // versions (chronological) so seller can't gaslight students by silently
  // rewriting their replies. Hard-capped to 10 entries in the route to
  // bound row size.
  editedAt        DateTime? @map("edited_at") @db.Timestamptz(6)
  editHistory     Json?     @map("edit_history")

  // Moderation — when >= AUTO_HIDE_THRESHOLD reports accumulate, the route
  // stamps hiddenAt and excludes the comment from public listings until an
  // admin resolves the reports.
  hiddenAt        DateTime? @map("hidden_at") @db.Timestamptz(6)
  hiddenReason    String?   @map("hidden_reason")

  lesson          Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  reports         CommentReport[]

  @@index([hiddenAt])
  @@map("comments")
}

/// User-submitted reports of inappropriate comments. Used by the student
/// "🚩 Báo cáo" UI and the admin moderation queue. A unique (commentId,
/// reporterId) ensures one user can't pile multiple reports onto the same
/// comment to game the auto-hide threshold.
model CommentReport {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId   String              @map("comment_id") @db.Uuid
  reporterId  String              @map("reporter_id") @db.Uuid
  reasonType  CommentReportReason @map("reason_type")
  note        String?
  status      CommentReportStatus @default(PENDING)
  /// Admin who resolved this report (null until resolution).
  resolvedById String?            @map("resolved_by_id") @db.Uuid
  resolvedAt  DateTime?           @map("resolved_at") @db.Timestamptz(6)
  /// Free-text resolution note (e.g. "Bị bỏ qua: không vi phạm").
  resolutionNote String?          @map("resolution_note")
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  comment     Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, reporterId])
  @@index([status, createdAt])
  @@map("comment_reports")
}

enum CommentReportReason {
  SPAM
  ABUSE
  SCAM
  MISINFORMATION
  OFF_TOPIC
  OTHER
}

enum CommentReportStatus {
  PENDING
  RESOLVED_REMOVED
  RESOLVED_KEPT
  DISMISSED
}

model Rating {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  score        Float
  userId       String    @map("user_id") @db.Uuid
  courseId     String    @map("course_id") @db.Uuid
  content      String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  isReported   Boolean   @default(false) @map("is_reported")
  repliedAt    DateTime? @map("replied_at") @db.Timestamptz(6)
  replyContent String?   @map("reply_content")
  course       Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("ratings")
}

model Report {
  content    String
  reasonType EReasonType @map("reason_type")
  userId     String      @map("user_id") @db.Uuid
  courseId   String      @map("course_id") @db.Uuid
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model UserLesson {
  lessonId String @map("lesson_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid
  /// When the learner first completed this lesson. Powers the "behind on
  /// progress" inactivity detection (latest completedAt per user+course = last
  /// study activity). Defaults to now() on insert.
  completedAt DateTime @default(now()) @map("completed_at") @db.Timestamptz(6)
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@id([lessonId, userId])
  @@index([userId])
  @@map("user_lessons")
}

model UserActivity {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  transactionId String    @map("transaction_id") @db.Uuid
  courseId      String    @map("course_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt     DateTime? @map("expires_at") @db.Timestamptz(6)
  /// Last time a "behind on progress" reminder was sent for this enrollment.
  /// Null = never reminded. Gates re-sends so the 60s cron can't spam learners.
  lastProgressReminderAt DateTime? @map("last_progress_reminder_at") @db.Timestamptz(6)
  course        Course    @relation(fields: [courseId], references: [id])

  @@index([lastProgressReminderAt])
  @@map("user_activities")
}

model Certificate {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Short human-readable code displayed on the certificate, e.g. "CERT-2024-A1B2C3D4"
  certificateNumber String   @unique @map("certificate_number") @db.VarChar(50)
  userId            String   @map("user_id") @db.Uuid
  courseId          String   @map("course_id") @db.Uuid
  /// Snapshot of the learner's name at issuance (guard against later profile edits)
  userName          String   @map("user_name") @db.VarChar(200)
  /// Snapshot of the course title at issuance
  courseName        String   @map("course_name") @db.VarChar(200)
  courseLevel       String?  @map("course_level") @db.VarChar(10)
  issuedAt          DateTime @default(now()) @map("issued_at") @db.Timestamptz(6)

  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@map("certificates")
}

enum CourseStatus {
  PENDING
  ACTIVE
  REFUSE
  INACTIVE
  DRAFT
}

enum CourseLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum MediaType {
  AUDIO
  IMAGE
  VIDEO
}

model NotificationOutbox {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType   String       @map("event_type")
  payload     Json
  status      OutboxStatus @default(PENDING)
  retryCount  Int          @default(0) @map("retry_count")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  processedAt DateTime?    @map("processed_at") @db.Timestamptz(6)

  @@index([status, createdAt])
  @@map("notification_outbox")
}

enum OutboxStatus {
  PENDING
  SENT
  FAILED
}

enum EReasonType {
  INAPPROPRIATE_CONTENT
  COPYRIGHT_VIOLATION
  NOT_AS_DESCRIBED
  UNRESPONSIVE_INSTRUCTOR
  INCOMPLETE_CONTENT
}

/// Durable archive of a completed AI livestream lesson. The live session lives in
/// Redis (rag-service) with a 7-day TTL; this is the permanent, queryable copy
/// written by rag-service via POST /api/livestream-recordings/internal when a
/// lesson finishes. `roomId` is the rag-service room id (not a DB FK — the room
/// lives in Redis, not Postgres), kept unique so re-saves upsert in place.
model LivestreamRecording {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId      String   @unique @map("room_id")
  topic       String
  level       String   @db.VarChar(20)
  levelLabel  String?  @map("level_label") @db.VarChar(50)
  /// User id of the host (from identity-service); plain string, no FK.
  hostId      String?  @map("host_id")
  hostName    String?  @map("host_name") @db.VarChar(200)
  language    String?  @db.VarChar(10)
  /// Slides: [{ index, title, content, audio_url, duration, practice_phrase,
  /// key_points, keywords, example, image_url }]
  sections    Json
  /// Q&A: [{ user_name, question, answer, audio_url }]
  qa          Json     @default("[]")
  completedAt DateTime @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([completedAt])
  @@index([hostId])
  @@map("livestream_recordings")
}
