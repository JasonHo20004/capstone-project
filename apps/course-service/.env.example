# Server
COURSE_SERVICE_PORT=3002
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/course_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT Secret (must match Identity Service)
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-change-in-production

# Service URLs
IDENTITY_SERVICE_URL=http://localhost:3001
