// =============================================================================
// Assessment Service - Prisma Schema
// Tables: Test, Section, Passage, Question, PracticeSession, UserAnswer,
//         EnglishTestType, ScoreConversion, CourseTest
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("ASSESSMENT_DATABASE_URL")
  directUrl = env("ASSESSMENT_DIRECT_URL")
}

model EnglishTestType {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String            @db.VarChar(100)
  scoreConversions ScoreConversion[]
  tests            Test[]

  @@map("english_test_types")
}

model Test {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String            @db.VarChar(255)
  slug              String?           @unique @db.VarChar(300)
  status            String            @default("DRAFT") @db.VarChar(50)
  durationInMinutes Int?              @map("duration_in_minutes")
  totalScore        Float?            @map("total_score")
  passingScore      Float?            @map("passing_score")
  englishTestTypeId String            @map("english_test_type_id") @db.Uuid
  practiceCount     Int?              @map("practice_count")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  maxAttempts       Int?              @map("max_attempts")
  testType          TestType?         @map("test_type")
  updatedAt         DateTime?         @updatedAt @map("updated_at") @db.Timestamptz(6)
  courseTests       CourseTest[]
  practiceSessions  PracticeSession[]
  questions         Question[]
  sections          Section[]
  testSkills        TestSkill[]
  testComments      TestComment[]
  englishTestType   EnglishTestType   @relation(fields: [englishTestTypeId], references: [id])

  @@map("tests")
}

model CourseTest {
  courseId String @map("course_id") @db.Uuid
  testId   String @map("test_id") @db.Uuid
  test     Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@id([courseId, testId])
  @@map("course_tests")
}

model Section {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String     @db.VarChar(100)
  testId            String?    @map("test_id") @db.Uuid
  skill             SkillType?
  durationInSeconds Float?     @map("duration_in_seconds")
  totalQuestions    Int?       @map("total_questions")
  totalScore        Float?     @map("total_score")
  mediaUrl          String?    @map("media_url")
  imageUrl          String?    @map("image_url")
  orderIndex        Int?       @map("order_index")
  passages          Passage[]
  questions         Question[]
  test              Test?      @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@map("sections")
}

model Passage {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId    String     @map("section_id") @db.Uuid
  content      String
  passageOrder Int?       @map("passage_order")
  section      Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questions    Question[]

  @@unique([sectionId, passageOrder])
  @@map("passages")
}

model Question {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId          String?      @map("section_id") @db.Uuid
  questionText       String?      @map("question_text")
  imageUrl           String?      @map("image_url")
  questionType       QuestionType @map("question_type")
  options            String[]
  correctAnswerIndex Int?         @map("correct_answer_index")
  wordLimit          Int?         @map("word_limit")
  correctAnswer      String?      @map("correct_answer")
  content            Json?        // JSONB: UI render data (options, gaps, prompts)
  answer             Json?        // JSONB: grading data (correct keys, variants)
  explanation        String?      // Shown to student after submission
  questionOrder      Int?         @map("question_order")
  passageId          String?      @map("passage_id") @db.Uuid
  mediaId            String?      @map("media_id") @db.Uuid
  testId             String?      @map("test_id") @db.Uuid
  passage            Passage?     @relation(fields: [passageId], references: [id], onDelete: Cascade)
  section            Section?     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  test               Test?        @relation(fields: [testId], references: [id], onDelete: Cascade)
  userAnswers        UserAnswer[]

  @@map("questions")
}

model PracticeSession {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  testId             String        @map("test_id") @db.Uuid
  selectedSections   String[]      @map("selected_sections")
  status             SessionStatus
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt        DateTime?     @map("completed_at") @db.Timestamptz(6)
  overallScaledScore Float?        @map("overall_scaled_score")
  rawScoresBySkill   Json?         @map("raw_scores_by_skill")
  scoresBySkill      Json?         @map("scores_by_skill")
  test               Test          @relation(fields: [testId], references: [id], onDelete: Cascade)
  userAnswers        UserAnswer[]

  @@map("practice_sessions")
}

model UserAnswer {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceSessionId   String          @map("practice_session_id") @db.Uuid
  questionId          String          @map("question_id") @db.Uuid
  userId              String          @map("user_id") @db.Uuid
  answerText          String?         @map("answer_text")
  selectedOptionIndex Int?            @map("selected_option_index")
  isCorrect           Boolean?        @map("is_correct")
  practiceSession     PracticeSession @relation(fields: [practiceSessionId], references: [id], onDelete: Cascade)
  question            Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([practiceSessionId, questionId, userId])
  @@map("user_answers")
}

model ScoreConversion {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  englishTestTypeId String          @map("english_test_type_id") @db.Uuid
  skill             SkillType
  rawScore          Int             @map("raw_score")
  scaledScore       Float           @map("scaled_score")
  englishTestType   EnglishTestType @relation(fields: [englishTestTypeId], references: [id])

  @@map("score_conversions")
}

model TestSkill {
  testId String    @map("test_id") @db.Uuid
  skill  SkillType
  test   Test      @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@id([testId, skill])
  @@map("test_skills")
}

enum SessionStatus {
  ONGOING
  COMPLETED
}

enum QuestionType {
  // General
  MULTIPLE_CHOICE
  MULTIPLE_CHOICE_MULTI_ANSWER
  ESSAY
  FILL_IN_THE_BLANK
  SHORT_ANSWER
  // IELTS auto-graded
  GAP_FILL
  MATCHING
  TRUE_FALSE_NOT_GIVEN
  YES_NO_NOT_GIVEN
  // TOEIC auto-graded
  TOEIC_SINGLE_CHOICE
  TOEIC_TEXT_COMPLETION
  // Future: AI / teacher graded (scaffolded, not yet implemented)
  IELTS_WRITING_TASK1
  IELTS_WRITING_TASK2
  IELTS_SPEAKING
  TOEIC_WRITING
  TOEIC_SPEAKING
}

enum SkillType {
  READING
  LISTENING
  WRITING
  SPEAKING
}

enum TestType {
  FINAL
}

// ─── Dictation Practice (IELTS Listening) ─────────────────────────────────────

model DictationExercise {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String   @db.VarChar(255)
  description    String?  @db.VarChar(500)
  audioUrl       String   @map("audio_url")
  level          String?  @db.VarChar(20)
  category       String?  @db.VarChar(100)
  totalSentences Int      @map("total_sentences")
  isPublished    Boolean  @default(false) @map("is_published")
  isPremium      Boolean  @default(false) @map("is_premium")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  sentences DictationSentence[]
  sessions  DictationSession[]

  @@map("dictation_exercises")
}

model DictationSentence {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exerciseId String @map("exercise_id") @db.Uuid
  index      Int
  text       String
  startTime  Float  @map("start_time")
  endTime    Float  @map("end_time")

  exercise DictationExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, index])
  @@map("dictation_sentences")
}

model DictationSession {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  exerciseId     String          @map("exercise_id") @db.Uuid
  currentIndex   Int             @default(0) @map("current_index")
  completedCount Int             @default(0) @map("completed_count")
  accuracy       Float?
  status         DictationStatus @default(IN_PROGRESS)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt    DateTime?       @map("completed_at") @db.Timestamptz(6)

  exercise DictationExercise @relation(fields: [exerciseId], references: [id])

  @@index([userId])
  @@map("dictation_sessions")
}

enum DictationStatus {
  IN_PROGRESS
  COMPLETED
}

// ─── Test Comments (Discussion) ───────────────────────────────────────────────

model TestComment {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  testId          String       @map("test_id") @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  content         String
  parentCommentId String?      @map("parent_comment_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  test            Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  parent          TestComment? @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         TestComment[] @relation("CommentReplies")

  @@index([testId])
  @@map("test_comments")
}
