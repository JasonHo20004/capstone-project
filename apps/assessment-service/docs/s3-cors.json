{
  "CORSRules": [
    {
      "AllowedOrigins": [
        "http://localhost:5173",
        "http://localhost:8080",
        "https://capstone.example.com"
      ],
      "AllowedMethods": ["GET", "HEAD"],
      "AllowedHeaders": ["Range", "If-Range", "If-None-Match", "If-Modified-Since"],
      "ExposeHeaders": [
        "Accept-Ranges",
        "Content-Range",
        "Content-Length",
        "Content-Type",
        "ETag",
        "Last-Modified"
      ],
      "MaxAgeSeconds": 3600
    }
  ]
}
