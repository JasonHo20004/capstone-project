ASSESSMENT_SERVICE_PORT=3003
NODE_ENV=development

# Database
ASSESSMENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/assessment_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT Secrets
ACCESS_TOKEN_SECRET=your-secret-key-change-in-production

# Groq LLM — powers the question-import LLM fallback (low-confidence parses).
# If unset, import gracefully falls back to deterministic parsing only.
GROQ_API_KEY=
