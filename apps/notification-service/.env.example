NOTIFICATION_SERVICE_PORT=3006
NODE_ENV=development

# Database
NOTIFICATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notification_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT Secrets
ACCESS_TOKEN_SECRET=your-secret-key-change-in-production

# SMTP (Gmail) — use a Google App Password, NOT your account password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="App Name <your-email@gmail.com>"
