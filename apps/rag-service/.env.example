# ── RAG Service (FastAPI) — example env ──────────────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit the real .env.

RAG_SERVICE_PORT=8000

# LLM provider: "gemini" (Google AI Studio, recommended) or "ollama" (local).
# Falls back to Ollama automatically if the Gemini key is empty or the API fails.
LLM_PROVIDER=gemini
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

FLASHCARD_SERVICE_URL=http://localhost:3004
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

REDIS_URL=redis://localhost:6379

# MUST equal identity-service ACCESS_TOKEN_SECRET — livestream verifies the
# access token issued by identity. Use a long random value in production.
JWT_SECRET=change-me-to-match-identity-ACCESS_TOKEN_SECRET

# TTS provider: "gcloud" (Google Cloud Neural2, best quality) or "edge" (free).
TTS_PROVIDER=gcloud
# Absolute path to a GCP service-account JSON (roles/texttospeech.user).
# Leave empty to auto-fallback to edge-tts.
GOOGLE_APPLICATION_CREDENTIALS=

# Pexels (free 200 req/hour) — slide images. https://www.pexels.com/api/
PEXELS_API_KEY=

# AWS S3 — when set, synthesized audio is uploaded and served from S3 (required
# for multi-worker / multi-replica deployments). Leave blank to serve from disk.
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Roles allowed to create/host a live room. Empty = any authenticated user may
# host. Valid roles in this system: ADMINISTRATOR, COURSESELLER, STUDENT.
# (To restrict hosting to staff: LIVESTREAM_HOST_ROLES=ADMINISTRATOR,COURSESELLER)
LIVESTREAM_HOST_ROLES=

# Where the browser fetches lesson/Q&A audio when S3 is NOT configured. Must be
# an origin the browser can reach: point it at the api-gateway, NOT this service,
# in any setup where rag-service isn't publicly exposed. Ignored when AWS_S3_* is
# configured (audio is then served from S3).
# AUDIO_BASE_URL=http://localhost:3000

# Comma-separated CORS origins (gateway + frontend per environment).
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# Live classroom limits
MAX_ROOM_PARTICIPANTS=30
QUESTIONS_PER_MINUTE=6
