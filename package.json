{
  "name": "capstone-microservices",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "pnpm install",
    "dev": "pnpm -r --parallel run dev",
    "dev:gateway": "pnpm --filter @capstone/api-gateway run dev",
    "dev:identity": "pnpm --filter @capstone/identity-service run dev",
    "dev:course": "pnpm --filter @capstone/course-service run dev",
    "dev:assessment": "pnpm --filter @capstone/assessment-service run dev",
    "dev:flashcard": "pnpm --filter @capstone/flashcard-service run dev",
    "dev:payment": "pnpm --filter @capstone/payment-service run dev",
    "dev:notification": "pnpm --filter @capstone/notification-service run dev",
    "dev:ai-evaluation": "pnpm --filter @capstone/ai-evaluation-service run dev",
    "build": "pnpm -r run build",
    "build:common": "pnpm --filter @capstone/common run build",
    "prisma:generate": "pnpm -r run prisma:generate",
    "prisma:migrate": "pnpm --filter @capstone/identity-service run prisma:migrate && pnpm --filter @capstone/course-service run prisma:migrate && pnpm --filter @capstone/assessment-service run prisma:migrate && pnpm --filter @capstone/flashcard-service run prisma:migrate && pnpm --filter @capstone/payment-service run prisma:migrate && pnpm --filter @capstone/notification-service run prisma:migrate && pnpm --filter @capstone/ai-evaluation-service run prisma:migrate",
    "prisma:migrate:identity": "pnpm --filter @capstone/identity-service run prisma:migrate",
    "prisma:migrate:course": "pnpm --filter @capstone/course-service run prisma:migrate",
    "prisma:migrate:assessment": "pnpm --filter @capstone/assessment-service run prisma:migrate",
    "prisma:migrate:flashcard": "pnpm --filter @capstone/flashcard-service run prisma:migrate",
    "prisma:migrate:payment": "pnpm --filter @capstone/payment-service run prisma:migrate",
    "prisma:migrate:notification": "pnpm --filter @capstone/notification-service run prisma:migrate",
    "prisma:migrate:ai-evaluation": "pnpm --filter @capstone/ai-evaluation-service run prisma:migrate",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "dev:rag": "cd apps/rag-service && venv\\Scripts\\python -m uvicorn app.main:app --reload --port 8000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed:demo:identity": "pnpm --filter @capstone/identity-service run seed:demo",
    "seed:demo:course": "pnpm --filter @capstone/course-service run seed:demo",
    "seed:demo:assessment": "pnpm --filter @capstone/assessment-service run seed:demo",
    "seed:demo:flashcard": "pnpm --filter @capstone/flashcard-service run seed:demo",
    "seed:demo:payment": "pnpm --filter @capstone/payment-service run seed:demo",
    "seed:demo:notification": "pnpm --filter @capstone/notification-service run seed:demo",
    "seed:demo:ai-evaluation": "pnpm --filter @capstone/ai-evaluation-service run seed:demo",
    "seed:demo": "pnpm run seed:demo:identity && pnpm run seed:demo:course && pnpm run seed:demo:assessment && pnpm run seed:demo:flashcard && pnpm run seed:demo:payment && pnpm run seed:demo:notification && pnpm run seed:demo:ai-evaluation"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^5.9.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
