# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/capstone_db"

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET="your-secret-key-here"
JWT_REFRESH_SECRET="your-refresh-secret-key-here"

# AWS S3 Configuration
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_BUCKET_NAME="capstone-videos"

# Redis Configuration
REDIS_URL="redis://127.0.0.1:6379"

# SMTP / Email Configuration
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="username"
SMTP_PASS="password"
EMAIL_FROM="no-reply@example.com"

# Frontend base URL (for links in emails)
FRONTEND_BASE_URL="http://localhost:8080"

# Optional explicit email verification URL override
EMAIL_VERIFICATION_BASE_URL="http://localhost:8080/auth/verify"

# Add other environment variables as needed


