generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String                   @unique @db.VarChar(100)
  password                String                   @db.VarChar(255)
  fullName                String                   @map("full_name") @db.VarChar(255)
  phoneNumber             String?                  @map("phone_number") @db.VarChar(20)
  profilePicture          String?                  @map("profile_picture") @db.VarChar(255)
  dateOfBirth             DateTime                 @map("date_of_birth") @db.Date
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  englishLevel            String?                  @map("english_level") @db.VarChar(100)
  learningGoals           String[]                 @map("learning_goals")
  role                    UserRole?
  refreshTokens           RefreshToken[]
  administratorProfile    AdministratorProfile?
  comments                Comment[]
  courseSellerApplication CourseSellerApplication?
  courseSellerProfile     CourseSellerProfile?
  courses                 Course[]
  flashcardDecks          FlashcardDeck[]
  inAppNotifications      InAppNotification[]
  policy                  Policy?
  practiceSessions        PracticeSession[]
  ratings                 Rating[]
  reports                 Report[]
  subscriptionContracts   SubscriptionContract[]
  topupOrders             TopupOrder[]
  userActivities          UserActivity[]
  userAnswers             UserAnswer[]
  userFlashcardProgress   UserFlashcardProgress[]
  userLessons             UserLesson[]
  userNotifications       UserNotification[]
  wallet                  Wallet?
  order                   Order[]
  cart                    Cart?
  @@map("users")
}

model RefreshToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hashedToken String   @unique @map("hashed_token")
  userId      String   @map("user_id") @db.Uuid
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationType {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String         @unique @db.VarChar(50)
  isLocked      Boolean        @default(false) @map("is_locked")
  notifications Notification[]

  @@map("notification_types")
}

model EnglishTestType {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String            @db.VarChar(100)
  scoreConversions ScoreConversion[]
  tests            Test[]

  @@map("english_test_types")
}

model Tag {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String    @unique @db.VarChar(100)
  deckTags DeckTag[]

  @@map("tags")
}

model SubscriptionPlan {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String                 @unique @db.VarChar(255)
  description           String?
  maxCourses            Int                    @map("max_courses")
  monthlyFee            Decimal                @map("monthly_fee") @db.Decimal(10, 2)
  subscriptionContracts SubscriptionContract[]

  @@map("subscription_plans")
}

model CourseSellerProfile {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  certification String[]
  expertise     String[]
  isActive      Boolean  @default(false) @map("is_active")
  userId        String   @unique @map("user_id") @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("course_seller_profiles")
}

model AdministratorProfile {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("administrator_profiles")
}

model CourseSellerApplication {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String            @unique @map("user_id") @db.Uuid
  certification   String[]
  expertise       String[]
  message         String?
  status          ApplicationStatus @default(PENDING)
  rejectionReason String?           @map("rejection_reason")
  createdAt       DateTime          @default(now()) @map("created_at")
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("course_seller_applications")
}


model Wallet {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  allowance    Decimal       @default(0.00) @db.Decimal(12, 2)
  userId       String        @unique @map("user_id") @db.Uuid
  transactions Transaction[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Notification {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title              String             @db.VarChar(255)
  content            String
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  seen               Boolean            @default(false)
  notificationTypeId String             @map("notification_type_id") @db.Uuid
  notificationType   NotificationType   @relation(fields: [notificationTypeId], references: [id], onDelete: Cascade)
  userNotifications  UserNotification[]

  @@map("notifications")
}

model InAppNotification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  title      String    @db.VarChar(255)
  content    String
  type       String    @db.VarChar(50)
  isRead     Boolean   @default(false) @map("is_read")
  isArchived Boolean   @default(false) @map("is_archived")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt     DateTime? @map("read_at") @db.Timestamptz(6)
  archivedAt DateTime? @map("archived_at") @db.Timestamptz(6)
  contractId String?   @map("contract_id") @db.Uuid
  courseId   String?   @map("course_id") @db.Uuid
  metadata   Json?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("in_app_notifications")
}

model Test {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String            @db.VarChar(100)
  durationInMinutes Int?              @map("duration_in_minutes")
  totalScore        Float?            @map("total_score")
  passingScore      Float?            @map("passing_score")
  englishTestTypeId String            @map("english_test_type_id") @db.Uuid
  practiceCount     Int?              @map("practice_count")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  maxAttempts       Int?              @map("max_attempts")
  testType          TestType?         @map("test_type")
  updatedAt         DateTime?          @updatedAt @map("updated_at") @db.Timestamptz(6)
  courseTests       CourseTest[]
  courses           Course[]
  practiceSessions  PracticeSession[]
  questions         Question[]
  sections          Section[]
  englishTestType   EnglishTestType   @relation(fields: [englishTestTypeId], references: [id])

  @@map("tests")
}

model CourseTest {
  courseId String @map("course_id") @db.Uuid
  testId   String @map("test_id") @db.Uuid
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  test     Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@id([courseId, testId])
  @@map("course_tests")
}

model FlashcardDeck {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String      @db.VarChar(100)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  description String?
  isPublic    Boolean     @default(true) @map("is_public")
  userId      String      @map("user_id") @db.Uuid
  deckTags    DeckTag[]
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcards  Flashcard[]

  @@map("flashcard_decks")
}

model TopupOrder {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  realMoney     Decimal       @map("real_money") @db.Decimal(12, 2)
  realAmount    Decimal?      @map("real_amount") @db.Decimal(12, 2)
  currency      String        @default("VND") @db.VarChar(10)
  paymentMethod PaymentMethod @map("payment_method")
  status        OrderStatus
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  user          User          @relation(fields: [userId], references: [id])
  transactions  Transaction[]

  @@map("topup_orders")
}

model ScoreConversion {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  englishTestTypeId String          @map("english_test_type_id") @db.Uuid
  skill             SkillType
  rawScore          Int             @map("raw_score")
  scaledScore       Float           @map("scaled_score")
  englishTestType   EnglishTestType @relation(fields: [englishTestTypeId], references: [id])

  @@map("score_conversions")
}

model UserNotification {
  notificationId String       @map("notification_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([notificationId, userId])
  @@map("user_notifications")
}

model Course {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String        @db.VarChar(100)
  description     String?
  price           Decimal       @db.Decimal(10, 2)
  category        String?       @db.VarChar(100)
  courseLevel     CourseLevel?  @map("course_level")
  courseSellerId  String        @map("course_seller_id") @db.Uuid
  finalTestId     String?       @map("final_test_id") @db.Uuid
  ratingCount     Int?          @map("rating_count")
  status          CourseStatus  @default(PENDING)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User          @relation(fields: [courseSellerId], references: [id], onDelete: Cascade)
  test            Test?         @relation(fields: [finalTestId], references: [id], onDelete: SetNull)
  courseTests     CourseTest[]
  ratings         Rating[]
  lessons         Lesson[]
  reports         Report[]
  cartItems       CartItem[]
  userActivities  UserActivity[]
  @@map("courses")
}

model Section {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String     @db.VarChar(100)
  testId            String?    @map("test_id") @db.Uuid
  skill             SkillType?
  durationInSeconds Float?     @map("duration_in_seconds")
  totalQuestions    Int?       @map("total_questions")
  totalScore        Float?     @map("total_score")
  passage           Passage[]
  questions         Question[]
  test              Test?      @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@map("sections")
}

model Flashcard {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  frontContent    String                  @map("front_content")
  backContent     String                  @map("back_content")
  exampleSentence String?                 @map("example_sentence")
  audioUrl        String?                 @map("audio_url")
  deckId          String                  @map("deck_id") @db.Uuid
  deck            FlashcardDeck           @relation(fields: [deckId], references: [id], onDelete: Cascade)
  userProgress    UserFlashcardProgress[]

  @@map("flashcards")
}

model DeckTag {
  tagId  String        @map("tag_id") @db.Uuid
  deckId String        @map("deck_id") @db.Uuid
  deck   FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  tag    Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([tagId, deckId])
  @@map("deck_tags")
}

model UserFlashcardProgress {
  userId       String          @map("user_id") @db.Uuid
  flashcardId  String          @map("flash_card_id") @db.Uuid
  status       FlashcardStatus @default(LEARNING)
  nextReviewAt DateTime        @default(now()) @map("next_review_at") @db.Timestamptz(6)
  repetitions  Int             @default(0)
  easeFactor   Float           @default(2.5) @map("ease_factor")
  interval     Int             @default(0)
  learningStep Int             @default(0) @map("learning_step")
  flashcard    Flashcard       @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, flashcardId])
  @@map("user_flashcard_progress")
}

model PracticeSession {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  testId           String        @map("test_id") @db.Uuid
  selectedSections String[]      @map("selected_sections")
  status           SessionStatus
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt      DateTime?     @map("completed_at") @db.Timestamptz(6)
  test             Test          @relation(fields: [testId], references: [id], onDelete: Cascade)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAnswers      UserAnswer[]

  @@map("practice_sessions")
}

model SubscriptionContract {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseSellerId     String           @map("course_seller_id") @db.Uuid
  status             Boolean          @default(true)
  subscriptionPlanId String           @map("subscription_plan_id") @db.Uuid
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt          DateTime         @map("expires_at") @db.Timestamptz(6)
  updatedAt          DateTime?       @updatedAt @map("updated_at") @db.Timestamptz(6)
  renewalCount       Int              @default(0) @map("renewal_count")
  lastRenewalAt      DateTime?        @map("last_renewal_at") @db.Timestamptz(6)
  notes              String?
  lastNotificationAt DateTime?        @map("last_notification_at") @db.Timestamptz(6)
  user               User             @relation(fields: [courseSellerId], references: [id])
  subscriptionPlan   SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])
  transactions       Transaction[]

  @@map("subscription_contracts")
}

model Rating {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  score       Float
  userId      String    @map("user_id") @db.Uuid
  courseId    String    @map("course_id") @db.Uuid
  content     String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  replyContent String?  @map("reply_content")
  repliedAt   DateTime? @map("replied_at") @db.Timestamptz(6)
  isReported  Boolean   @default(false) @map("is_reported")
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("ratings")
}

model Transaction {
  id                      String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  amount                  Decimal           @db.Decimal(12, 2)
  status                  TransactionStatus
  createdAt               DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  description             String?
  walletId                String            @map("wallet_id") @db.Uuid
  transactionType         TransactionType   @map("transaction_type")
  topupOrderId            String?           @map("topup_order_id") @db.Uuid
  subscriptionContractId  String?           @map("subscription_contract_id") @db.Uuid
  wallet                  Wallet            @relation(fields: [walletId], references: [id])
  topupOrder              TopupOrder?       @relation(fields: [topupOrderId], references: [id])
  subscriptionContract    SubscriptionContract? @relation(fields: [subscriptionContractId], references: [id])
  userActivities          UserActivity[]
  orderId     String?   @unique @map("order_id") @db.Uuid 
  order       Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  @@map("transactions")
}

model CartItem {
  id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId String @map("course_id") @db.Uuid
  addedAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6) 
  priceAtTime Float @map("price_at_time")
  cartId String @map("cart_id") @db.Uuid
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cart Cart  @relation(fields: [cartId], references: [id], onDelete: Cascade)
  @@map("cart_items")
}
model Cart {
  id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId   String?  @unique @map("user_id") @db.Uuid
  user     User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6) 
  order Order[]
  cartItems CartItem[]
  @@map("carts")
}
model Order {
  id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId   String @map("user_id") @db.Uuid
  totalAmount Float @map("total_amount") 
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6) 
  cartId String  @map("cart_id") @db.Uuid
  transactionId String? @map("transaction_id") @db.Uuid
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cart     Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  transaction Transaction?
  @@map("orders")

}

// Placeholder models for complete relationships
model UserLesson {
  lessonId String @map("lesson_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([lessonId, userId])
  @@map("user_lessons")
}


model UserAnswer {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceSessionId   String          @map("practice_session_id") @db.Uuid
  questionId          String          @map("question_id") @db.Uuid
  userId              String          @map("user_id") @db.Uuid
  answerText          String?         @map("answer_text")
  selectedOptionIndex Int?            @map("selected_option_index")
  isCorrect           Boolean?        @map("is_correct")
  practiceSession     PracticeSession @relation(fields: [practiceSessionId], references: [id], onDelete: Cascade)
  question            Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_answers")
}

model UserActivity {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  transactionId String      @map("transaction_id") @db.Uuid
  courseId      String      @map("course_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt     DateTime?   @map("expires_at") @db.Timestamptz(6)
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
  @@map("user_activities")
}

model Comment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content         String
  userId          String   @map("user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  parentCommentId String?  @map("parent_comment_id") @db.Uuid
  lessonId        String   @map("lesson_id") @db.Uuid
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Lesson {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String       @db.VarChar(100)
  description       String?
  durationInSeconds Float?       @map("duration_in_seconds")
  lessonOrder       Int?         @map("lesson_order")
  materials         String[]
  commentCount      Int?         @map("comment_count")
  courseId          String       @map("course_id") @db.Uuid
  comments          Comment[]
  course            Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  mediaAssets       MediaAsset[]
  userLessons       UserLesson[]

  @@map("lessons")
}

model Passage {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId    String     @map("section_id") @db.Uuid
  content      String
  passageOrder Int?       @map("passage_order")
  section      Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questions    Question[]

  @@unique([sectionId, passageOrder])
  @@map("passages")
}

model MediaAsset {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetType       MediaType  @map("asset_type")
  assetUrl        String     @unique @map("asset_url")
  lessonId        String     @map("lesson_id") @db.Uuid
  lesson          Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions       Question[]

  @@map("media_assets")
}

model Question {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId          String?      @map("section_id") @db.Uuid
  questionText       String?      @map("question_text")
  imageUrl           String?      @map("image_url")
  questionType       QuestionType @map("question_type")
  options            String[]
  correctAnswerIndex Int?         @map("correct_answer_index")
  wordLimit          Int?         @map("word_limit")
  correctAnswer      String?      @map("correct_answer")
  passageId          String?      @map("passage_id") @db.Uuid
  mediaId            String?      @map("media_id") @db.Uuid
  questionOrder      Int?         @map("question_order")
  testId             String?      @map("test_id") @db.Uuid
  mediaAsset         MediaAsset?  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  passage            Passage?     @relation(fields: [passageId], references: [id], onDelete: Cascade)
  section            Section?     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  test               Test?        @relation(fields: [testId], references: [id], onDelete: Cascade)
  userAnswers        UserAnswer[]

  @@map("questions")
}

model Policy {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  userId    String   @unique @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("policies")
}

model Report {
  content    String
  reasonType EReasonType @map("reason_type")
  userId     String      @map("user_id") @db.Uuid
  courseId   String      @map("course_id") @db.Uuid
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reports")
}

enum UserRole {
  ADMINISTRATOR
  COURSESELLER
}

enum PaymentMethod {
  MOMO
  ZALOPAY
  BANKING
  APPLEPAY
}

enum OrderStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TransactionType {
  DEPOSIT
  PAYMENT
  MONTHLYFEE
  WITHDRAW
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum CourseStatus {
  PENDING
  ACTIVE
  REFUSE
  INACTIVE
  DELETE
  DRAFT
  PUBLISHED
}

enum CourseLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum SessionStatus {
  ONGOING
  COMPLETED
}

enum QuestionType {
  MULTIPLE_CHOICE
  ESSAY
  FILL_IN_THE_BLANK
